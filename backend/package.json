{
  "name": "sbi-banking-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/schema-corporate.prisma && tsc && rm -rf dist/generated && cp -r generated dist/generated",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "seed": "tsx src/scripts/seed.ts",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma && prisma generate --schema=prisma/schema-corporate.prisma",
    "prisma:migrate:personal": "prisma migrate dev --schema=prisma/schema.prisma --name init",
    "prisma:migrate:corporate": "prisma migrate dev --schema=prisma/schema-corporate.prisma --name init",
    "prisma:push:personal": "prisma db push --schema=prisma/schema.prisma",
    "prisma:push:corporate": "prisma db push --schema=prisma/schema-corporate.prisma",
    "prisma:studio:personal": "prisma studio --schema=prisma/schema.prisma",
    "prisma:studio:corporate": "prisma studio --schema=prisma/schema-corporate.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "cloudinary": "^2.4.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "otplib": "^12.0.1",
    "pg": "^8.21.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
